├── chart/
│   ├── ag-chart/                         # AG-Chart 元件
│   ├── chart.api.d.ts                    # 圖表 API
│   └── chart.module.d.ts                 # 圖表模組

# 🎯 dlp-shared-material (Material UI)
├── material/                             # Material Design 元件封裝
├── models/
│   └── material.model.d.ts               # Material 模型定義

# 🎯 dlp-shared-services (共享服務)
├── services/
│   ├── api/                              # API 相關服務
│   ├── auth/                             # 認證服務
│   ├── cache/                            # 快取服務
│   ├── notification/                     # 通知服務
│   └── utility/                          # 工具服務
└── models/
    └── service.model.d.ts                # 服務模型定義

# 🎯 dlp-shared-states (狀態管理)
├── states/
│   ├── base-state.d.ts                   # 基礎狀態類別
│   ├── app-state.d.ts                    # 應用程式狀態
│   └── component-state.d.ts              # 元件狀態
└── models/
    └── state.model.d.ts                  # 狀態模型

# 🎯 dlp-shared-utils (工具函式)
├── utils/
│   ├── date/                             # 日期工具
│   ├── format/                           # 格式化工具
│   ├── validation/                       # 驗證工具
│   └── common/                           # 通用工具
└── models/
    └── util.model.d.ts                   # 工具模型

# 🎯 dlp-shared-directives (指令)
├── directives/
│   ├── form/                             # 表單指令
│   ├── grid/                             # 網格指令
│   └── common/                           # 通用指令

# 🎯 dlp-shared-pipes (管道)
├── pipes/
│   ├── date/                             # 日期管道
│   ├── format/                           # 格式化管道
│   └── currency/                         # 幣值管道

# 🎯 其他套件
├── dlp-shared-chat/lib/                  # 聊天元件
├── dlp-shared-form-base/lib/             # 表單基礎
├── dlp-shared-gallery-images/lib/        # 圖片庫
└── dlp-shared-models/lib/                # 共享模型
```

**🚨 AI 絕對必須遵循的流程：**

1. **先 Read 型別定義，再寫程式碼**：絕對不可在未查閱型別定義的情況下使用任何 dlp-shared-\* API
2. **禁止猜測任何 API**：屬性名稱、方法名稱、enum 值、介面結構都必須以實際型別定義為準
3. **使用具體檔案路徑**：查閱時使用完整路徑，如 `node_modules/dlp-shared-datagrid/lib/states/grid.refs.d.ts`
4. **記住 API 結構**：AI 記憶力佳，一旦查閱過可記住常用 API 結構供後續使用

#### **路徑錯誤 (Import Path Issues)**

```
Cannot find module '../controls/xxx.control'
```

**❌ 錯誤原因**：Component 在 `pages/xxx/` 子目錄中，相對路徑計算錯誤

**✅ 解決方案**：

```typescript
// ❌ 錯誤的路徑（在pages子目錄中）
import { Clq080Control } from "../controls/clq080.control";

// ✅ 正確的路徑（向上兩層）
import { Clq080Control } from "../../controls/clq080.control";
```

#### **Grid 欄位類型錯誤 (Grid Column Type Error)**

```
Property 'numeric' does not exist on type 'typeof EDlpGridColumnType'
```

**❌ 錯誤原因**：使用了不存在的 `EDlpGridColumnType.numeric`

**✅ 解決方案**：查閱 `ag-grid-components.model.d.ts:81-91` 的正確定義

```typescript
// ❌ 錯誤的類型（不存在）
type: EDlpGridColumnType.numeric,

// ✅ 正確的類型（來自型別定義）
type: EDlpGridColumnType.number,

// 📚 完整的 EDlpGridColumnType 定義：
// text | date | number | lov | checkbox | select | radio | button | image
```

#### **Grid API 方法錯誤 (Grid API Method Error)**

```
Property 'selectedRowData' does not exist on type 'DlpGridRefs'
```

**❌ 錯誤原因**：使用了不存在的 `selectedRowData` 屬性

**✅ 解決方案**：查閱 `grid.refs.d.ts:113-198` 的正確 API

```typescript
// ❌ 錯誤的API（不存在）
CL040_GOOD_NO: this._state.cl040GridRefs?.selectedRowData?.CL040_GOOD_NO,

// ✅ 正確的API（來自型別定義）
CL040_GOOD_NO: this._state.cl040GridRefs.getSelectedRow()?.CL040_GOOD_NO,

// 📚 DlpGridRefs 主要方法：
// getSelectedRow(): any
// getSelectedRowIndex(): number
// executeQueryByInfo(): void
```

#### **編譯檢查命令**

**快速檢查**：

```bash
cd DLP.Web/DLP.Web.AppPortal/ClientApp
npx tsc --noEmit --skipLibCheck
```

**完整檢查**：

```bash
cd DLP.Web/DLP.Web.AppPortal/ClientApp
npm run build
```

### 2.1.5 架構一致性檢查

**🔍 AI必須檢查的一致性項目：**

**1. Service方法命名一致性**

```typescript
// ✅ 標準命名模式
public getCl040QueryInfo = (): IDlpGridQueryInfo => { ... }
public updateCl040 = ($event: DlpGridSaveEvent): void => { ... }
public deleteCl040 = ($event: DlpGridDeleteRowEvent): void => { ... }
```

**2. 主從關係查詢一致性**

```typescript
// ✅ 明細表查詢必須使用主表外鍵
public getCl050QueryInfo = (): IDlpGridQueryInfo => {
  const selectedRow = this._state.cl040GridRefs.getSelectedRow();
  return {
    actionOrSpName: 'PK_CL_CLQ080.PC_CLQ080_QUERY_CL050',
    queryParams: {
      payload: { CL050_GOOD_NO: selectedRow?.CL040_GOOD_NO },
      refCursorKeys: ['vResult', 'vCount'],
    },
  };
};
```

**3. 錯誤處理一致性**

```typescript
// ✅ 標準錯誤處理模式
response: (res: any) => {
  if (res.resCode != '1') {
    this._notificationService.showWarning("具體中文錯誤訊息");
  }
};

// ✅ Dataset 映射規則 (Table Mapping)
// 當使用 callSpDataSet 且後端開啟多個游標時，前端接收到的 Dataset 鍵值固定依照順序：
// Table (第1個 - 通常是資料), Table1 (第2個 - 通常是總筆數), Table2 (第3個)
const totalCount = res.dsResult?.Table1?.[0]?.TOTAL_COUNT;

```

### 2.1.6 AI 綜合開發檢查清單 (AI Comprehensive Development Checklist)

為確保開發品質並遵循專案規範，請在開發的各個階段確實執行以下檢查：

---

#### **階段一：開發前 (Pre-Development)**

**需求與分析**

- [ ] **確認需求**: 已與使用者充分溝通，完全理解業務需求和功能範圍。
- [ ] **排除假設**: 已排除所有對業務邏輯的個人假設，所有功能點均有使用者確認。
- [ ] **參考研究**: 已使用 `rg` 等搜尋工具，找到並深入研讀指定的參考實作 (`DPI580DG` for Grid, `FXR050DG` for Form)。

**環境與路徑**

- [ ] **路徑確認**: 已確認新檔案的目標路徑 (`DLP.Web/DLP.Web.AppPortal/ClientApp/src/app/views/...`) 是否正確。
- [ ] **模組確認**: 已確認目標模組 (e.g., `wo`, `dp`) 和地區代碼 (e.g., `dg`, `vn`) 是否存在且正確。
- [ ] **檔案結構**: 確認新程式直接位於 `[地區]/[功能ID]/` 下，**嚴禁**建立 `pages/` 資料夾。


---

#### **階段二：開發中 (During Development)**

**前端 (Frontend)**

- [ ] **架構一致性**: 確認 `State-Control-Service-Component` 的職責劃分清晰，與參考實作模式一致。
- [ ] **HTML 模板**:
  - [ ] 確認使用 `<resize-layout>` 進行佈局，未使用原生 `div`/`span` 排版。
  - [ ] 確認 `dlp-grid` 的屬性為 `[gridRefs]`，而非 `[dlpGridRefs]`。
  - [ ] 確認 `<ng-template>` 的 `key` 與 `state.ts` 中的 `layoutRefs` 配置完全一致。
- [ ] **TypeScript**:
  - [ ] 確認 `import` 路徑符合專案規範 (e.g., `app/shared/states/resize-layout.refs`)。
  - [ ] 確認 `service` 的返回類型使用 `<IDlpGridQueryInfo>{...}` 類型斷言。
  - [ ] 確認所有 `subscribe` 和 `response` 的回呼參數 `(res: any)` 都有明確類型或註解。
  - [ ] 確認主從 `grid` 聯動時，明細查詢有使用主表外鍵，並在主表查詢前清空明細。
- [ ] **API 呼叫**:
  - [ ] 確認刪除操作使用 `executeDelete` 方法，而非通用的 `callStoreProcedureDataSet`。
  - [ ] 確認錯誤處理 `response` 回呼中，是檢查 `res.resCode != '1'`。

**後端 & 資料庫 (Backend & Database)**

- [ ] **PKG 結構**:
  - [ ] **Spec 簽章**: 確認 Package Specification **禁止包含任何註解**，僅宣告簽章。
  - [ ] **單一檔案**: 確認 PKG 檔案為包含 Specification 和 Body 的單一檔案。
  - [ ] **命名規範**: PKG 命名 (`PK_[MODULE]_[PROGRAM_CODE]`) 和程序命名 (`PC_[PROGRAM_CODE]_[ACTION]_[TABLE]`) 符合規範。
- [ ] **註解區塊強制規範**:
  - [ ] **分隔線**: 使用 `/* ` 加上 **76 個虛線** (`----------------------------------------------------------------------------`)。
  - [ ] **對齊**: 所有內容行開頭必須為 **`--   `** (雙橫線後接三個空格)。
  - [ ] **欄位留空**: `輸入資料:` 與 `注意事項:` 欄位 **必須保持空值** (Empty)。
  - [ ] **異動紀錄**: 必須包含異動日期、異動者、異動說明。
- [ ] **PKG 邏輯**:
  - [ ] 確認查詢包含 `vResult` 和 `vCount` 兩個 `OUT SYS_REFCURSOR`。
  - [ ] 確認分頁邏輯使用 `Row_Number()` 並搭配 `vSQLStmt` 共用變數。
  - [ ] 確認 `SQLERRM` **禁止直接寫在 SELECT 中**（必須先賦值給區域變數）。
  - [ ] 業務阻擋回傳負數代碼 (`'-2'`, `'-3'`)，且 **禁止在 RES_MSG 回傳中文**（訊息附在 SQL 註解中）。


---

#### **階段三：開發後 (Post-Development)**

- [ ] **功能驗證**:
  - [ ] 主從 Grid 聯動功能 (查詢、清空) 正常。
  - [ ] Grid 的 `suppressAutoSearchAfterReady` 屬性在明細表上設定正確。
  - [ ] 分頁和總行數顯示正常。
- [ ] **權限與部署**:
  - [ ] 確認 Grid 的 `allowInsert`, `allowUpdate`, `allowDelete` 權限設定符合需求。
  - [ ] **(最重要)** 確認已在對應的 `grant_[模組].sql` 檔案中新增 `GRANT execute` 授權。
- [ ] **程式碼整潔**:
  - [ ] 移除所有不必要的 `console.log` 和開發中的註解。
  - [ ] 確認 Grid 欄位配置無 `editable: false` 等不必要的多餘屬性。
  - [ ] 確認 SCSS 檔案為空。

### 2.1.7 強制參考模式

**🚨 AI必須強制遵循的參考程式：**

- **Grid功能**: 完全參考 `DPI580DG` 的實作模式
- **Form功能**: 完全參考 `FXR050DG` 的實作模式
- **刪除操作**: 使用 `executeDelete` 方法，包含完整的錯誤處理
- **HTML模板**: 使用正確的屬性名稱和事件綁定
- **主從關係**: 明細查詢必須使用主表選中行的外鍵資料

**⚠️ 禁止自創模式**：AI不得偏離這些參考程式的標準實作方式

### 2.1.8 重要技術細節補充（基於CLQ080VN實戰經驗）

**🔧 Import路徑標準化**

```typescript
// ✅ 正確的Import路徑
import { ResizeLayoutTemplateDirective } from "dlp-shared-directives";
import { ResizeLayoutRefs } from "app/shared/states/resize-layout.refs";
import {
  DlpGridRefs,
  DlpColDef,
  EDlpGridColumnType,
} from "dlp-shared-datagrid";
import { ECommonApiType } from "dlp-shared-models";
```

**🔧 Layout Key命名一致性（重要！）**

```typescript
// State中的key
layoutRefs = new ResizeLayoutRefs({
  config: {
    rows: [
      {
        cols: [
          { widthFlex: 60, key: "cl040GridRefsTemplate" }, // ✅ key名稱
        ],
      },
    ],
  },
});
```

```html
<!-- HTML中的key必須完全一致 -->
<ng-template resizeLayoutTemplate key="cl040GridRefsTemplate">
  <!-- ✅ 相同key -->
  <dlp-grid [gridRefs]="state.cl040GridRefs"></dlp-grid>
</ng-template>
```

**🔧 Grid配置必要屬性**

```typescript
// ✅ 完整的gridConfig配置
this.state.cl040GridRefs.gridConfig = {
  name: "clq080.state.cl040GridRefs", // 必要：Grid名稱
  apiParams: this._apiParams, // 必要：API參數
  columnDefs: this._control.getCl040GridColDefs(), // 必要：欄位定義
  getQueryInfo: () => this._service.getCl040QueryInfo(), // 必要：查詢資訊
  displayRowCountInfo: true, // 顯示行數資訊
  getRowTotalCount: (result: any) => {
    // 必要：總行數計算
    return result.dsResult.Table1[0].TOTAL_COUNT;
  },
  gridHeight: "50vh", // 必要：指定 Grid 高度，建議使用 'vh' (Viewport Height) 單位以適應不同螢幕
  headerHeight: 40, // 標題高度
  pageSize: 100, // 分頁大小
  allowInsert: false, // CRUD權限控制
  allowUpdate: false,
  allowDelete: false,
  suppressAutoSearchAfterReady: true, // 明細表專用：不自動查詢
};
```

**🔧 主從Grid聯動標準模式**

```typescript
// ✅ 主表選擇事件處理
public onCL040RowSelected = (): void => {
  const selectedRow = this.state.cl040GridRefs.getSelectedRow();
  if (selectedRow && selectedRow.CL040_GOOD_NO) {
    // 重新查詢明細表
    this.state.cl050GridRefs.executeQueryByInfo();
  } else {
    // 清空明細表
    this.state.cl050GridRefs?.dlpGridApi?.clearGrid();
  }
};

// ✅ 主表查詢前清空明細表
getQueryInfo: () => {
  this.state.cl050GridRefs?.dlpGridApi?.clearGrid(); // 清空明細
  return this._service.getCl040QueryInfo();
}
```

**🔧 PKG雙Cursor查詢標準**

```sql
-- ✅ 標準的PKG查詢程序（需要兩個OUT Cursor）
PROCEDURE PC_CLQ080_QUERY_CL040 (
    vJson CLOB,
    vResult OUT SYS_REFCURSOR,  -- 查詢結果
    vCount OUT SYS_REFCURSOR    -- 總數統計
);

-- ✅ 實作範例
OPEN vResult FOR vSQLStmt;

OPEN vCount FOR
    SELECT COUNT(*) AS TOTAL_COUNT
    FROM CL040
    WHERE 1=1;
```

**🔧 Service查詢方法標準**

```typescript
// ✅ 標準的查詢資訊提供方法
public getCl040QueryInfo = (): IDlpGridQueryInfo => {
  return <IDlpGridQueryInfo>{
    actionOrSpName: 'PK_CL_CLQ080.PC_CLQ080_QUERY_CL040',
    queryParams: {
      payload: {},
      refCursorKeys: ['vResult', 'vCount'], // 對應PKG的兩個Cursor
      error: () => {
        this._notificationService.showWarning('系統發生錯誤，請通知電腦室人員！');
      },
    },
  };
};
```

