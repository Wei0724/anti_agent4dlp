    └── notification.service.d.ts         # 通知服務

# 🎯 dlp-shared-button-authority (按鈕權限)
├── button-authority/
│   ├── button-authority.component.d.ts   # 權限按鈕元件
│   ├── button-authority.module.d.ts      # 模組定義
│   └── buttons/
│       └── buttons.component.d.ts        # 按鈕群組元件

# 🎯 dlp-shared-chart (圖表元件)
├── model/
